# Render: usar preferentemente la URL interna del PostgreSQL en la misma región.
DATABASE_URL=postgresql://usuario:password@host:5432/foodsave?sslmode=require

# Alternativa en formato Npgsql. Si se configuran ambas variables, esta tiene
# precedencia sobre DATABASE_URL.
# ConnectionStrings__DefaultConnection=Host=host;Port=5432;Database=foodsave;Username=usuario;Password=password;SSL Mode=Require;Trust Server Certificate=true

ASPNETCORE_ENVIRONMENT=Production

# Render inyecta PORT automáticamente. No fijar un valor en producción.
# PORT=
