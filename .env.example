# Railway puede inyectar esta variable al vincular el servicio PostgreSQL.
DATABASE_URL=postgresql://usuario:password@host:5432/foodsave?sslmode=require

# Alternativa compatible con la configuración estándar de ASP.NET Core.
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=foodsave;Username=foodsave;Password=foodsave

ASPNETCORE_ENVIRONMENT=Production
PORT=8080
