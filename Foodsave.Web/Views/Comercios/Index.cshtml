@model List<Foodsave.Web.Models.ComercioAdministracionViewModel>

@{
    ViewData["Title"] = "Comercios";
}

<section class="py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h2 mb-2">Comercios</h1>
            <p class="lead mb-0">
                Administrá comercios, suscripciones y estados de pago.
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-self-md-start">
            <a class="btn btn-primary"
               asp-controller="Comercios"
               asp-action="Create">
                Inscribir comercio
            </a>
            <a class="btn btn-outline-primary"
               asp-controller="Estadisticas"
               asp-action="Index">
                Ver estadísticas
            </a>
        </div>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }

    <div class="admin-card">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Comercio</th>
                        <th>Estado</th>
                        <th>Plan</th>
                        <th>Pago</th>
                        <th>Próximo vencimiento</th>
                        <th>Contacto</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var comercioStatusClass =
                                item.Comercio.EstadoAdministrativo switch
                                {
                                    EstadoAdministrativo.Activo => "status-accepted",
                                    EstadoAdministrativo.Inhabilitado => "status-rejected",
                                    _ => "status-pending"
                                };
                            var pagoStatusClass = item.EstadoPagoEfectivo switch
                            {
                                EstadoPagoSuscripcion.AlDia => "status-accepted",
                                EstadoPagoSuscripcion.Vencido => "status-rejected",
                                _ => "status-pending"
                            };

                            <tr>
                                <td>
                                    <strong>@item.Comercio.Nombre</strong>
                                    <div class="small text-muted">@item.Comercio.Rubro</div>
                                </td>
                                <td>
                                    <span class="status-badge @comercioStatusClass">
                                        @item.Comercio.EstadoAdministrativo
                                    </span>
                                </td>
                                <td>@(item.SuscripcionActual?.Plan.ToString() ?? "Sin plan")</td>
                                <td>
                                    <span class="status-badge @pagoStatusClass">
                                        @item.EstadoPagoEfectivo
                                    </span>
                                </td>
                                <td>
                                    @(item.SuscripcionActual?.FechaProximoVencimiento
                                        .ToString("dd/MM/yyyy") ?? "Sin fecha")
                                </td>
                                <td>@item.Comercio.Telefono</td>
                                <td>
                                    <a class="btn btn-sm btn-outline-primary"
                                       asp-action="Details"
                                       asp-route-id="@item.Comercio.Id">
                                        Ver detalle
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                Todavía no hay comercios cargados.
                                <a class="btn btn-link btn-sm p-0 ms-2 align-baseline" asp-action="Create">
                                    Inscribir el primero
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
