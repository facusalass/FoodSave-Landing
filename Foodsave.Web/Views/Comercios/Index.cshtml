@model List<Foodsave.Web.Models.Comercio>

@{
    ViewData["Title"] = "Comercios";
}

<section class="py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h2 mb-2">Comercios</h1>
            <p class="lead mb-0">
                Comercios que publican ofertas del d&iacute;a o Mystery Boxes.
            </p>
        </div>
        <div class="d-flex gap-2 align-self-md-start">
            <a class="btn btn-primary" asp-controller="Comercios" asp-action="Create">Inscribir comercio</a>
            <a class="btn btn-outline-primary" asp-controller="Home" asp-action="Index">Volver al inicio</a>
        </div>
    </div>

    <div class="admin-card">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Comercio</th>
                        <th>Rubro</th>
                        <th>Direcci&oacute;n</th>
                        <th>Contacto</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var comercio in Model)
                        {
                            <tr>
                                <td>@comercio.Nombre</td>
                                <td>@comercio.Rubro</td>
                                <td>@comercio.Direccion</td>
                                <td>@comercio.Telefono</td>
                                <td>
                                    <a class="btn btn-sm btn-outline-primary" asp-controller="Comercios" asp-action="Details" asp-route-id="@comercio.Id">Ver detalle</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                Todav&iacute;a no hay comercios cargados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
