@model Foodsave.Web.Models.ComercioAdministracionViewModel
@{
    ViewData["Title"] = "Suscripciones";
    var comercio = Model.Comercio;
    var suscripcion = (Foodsave.Web.Models.Suscripcion?)ViewData["SuscripcionActual"];
    var estadoPago = (Foodsave.Web.Models.EstadoPagoSuscripcion)(ViewData["EstadoPago"] ?? EstadoPagoSuscripcion.Pendiente);
}

<section class="py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h2 mb-2">Suscripciones de @comercio.Nombre</h1>
            <p class="lead mb-0">@comercio.Rubro</p>
        </div>
        <a class="btn btn-outline-primary align-self-md-start"
           asp-action="Details" asp-route-id="@comercio.Id">
            Volver al comercio
        </a>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger">@error</div>
    }

    <div class="row g-4">
        <div class="col-lg-6">
            @if (suscripcion is not null)
            {
                <div class="admin-card h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h2 class="h5 mb-1">Suscripci&oacute;n actual</h2>
                            <span class="status-badge @(estadoPago == EstadoPagoSuscripcion.AlDia ? "status-accepted" : estadoPago == EstadoPagoSuscripcion.Vencido ? "status-rejected" : "status-pending")">
                                @estadoPago
                            </span>
                        </div>
                        <span class="badge bg-light text-dark">
                            @suscripcion.Plan
                        </span>
                    </div>

                    <form asp-action="EditarSuscripcion" asp-route-id="@comercio.Id" method="post">
                        <input type="hidden" name="ComercioId" value="@comercio.Id" />
                        <input type="hidden" name="SuscripcionId" value="@suscripcion.Id" />

                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small">Plan</label>
                                <select name="Plan" class="form-select form-select-sm">
                                    <option value="Estandar" selected="@(suscripcion.Plan == PlanSuscripcion.Estandar)">Est&aacute;ndar</option>
                                    <option value="Pro" selected="@(suscripcion.Plan == PlanSuscripcion.Pro)">Pro</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="form-label small">Monto mensual</label>
                                <input name="MontoMensual" type="number" min="0" step="0.01"
                                       value="@suscripcion.MontoMensual.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                       class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small">Pr&oacute;ximo vencimiento</label>
                                <input name="FechaProximoVencimiento" type="date"
                                       value="@suscripcion.FechaProximoVencimiento.ToString("yyyy-MM-dd")"
                                       class="form-control form-control-sm" />
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-outline-primary btn-sm"
                                    data-bs-toggle="tooltip" data-bs-placement="top"
                                    title="Guarda los cambios de plan, monto mensual y vencimiento.">
                                Guardar cambios
                            </button>
                        </div>
                    </form>

                    <hr class="my-3" />

                    <div class="row g-1 small text-muted mb-3">
                        <div class="col-6">Inicio: @suscripcion.FechaInicio.ToString("dd/MM/yyyy")</div>
                        <div class="col-6">&Uacute;ltimo pago: @(suscripcion.FechaUltimoPago?.ToString("dd/MM/yyyy") ?? "—")</div>
                        <div class="col-6">Estado: @suscripcion.Estado</div>
                    </div>

                    <form asp-action="CancelarSuscripcion" asp-route-id="@comercio.Id"
                          asp-route-suscripcionId="@suscripcion.Id" method="post"
                          onsubmit="return confirm('¿Cancelar esta suscripci&oacute;n? El historial se conserva.');">
                        <button type="submit" class="btn btn-outline-danger btn-sm"
                                data-bs-toggle="tooltip" data-bs-placement="top"
                                title="Cancela la suscripción. El historial de pagos se conserva.">
                            Cancelar suscripci&oacute;n
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="admin-card h-100 d-flex flex-column justify-content-center text-center" style="min-height:200px;">
                    <p class="text-muted mb-3">Este comercio no tiene una suscripci&oacute;n activa.</p>
                    <p class="small text-muted">Us&aacute; el formulario de la derecha para crear una.</p>
                </div>
            }
        </div>

        <div class="col-lg-6">
            <div class="admin-card h-100">
                <h2 class="h5 mb-3">Nueva suscripci&oacute;n</h2>
                <form asp-action="CrearSuscripcion" asp-route-id="@comercio.Id" method="post">
                    <input type="hidden" name="ComercioId" value="@comercio.Id" />

                    <div class="row g-2">
                        <div class="col-6">
                            <label class="form-label small">Plan</label>
                            <select name="Plan" class="form-select form-select-sm">
                                <option value="Estandar">Est&aacute;ndar</option>
                                <option value="Pro">Pro</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Monto mensual (ARS)</label>
                            <input name="MontoMensual" type="number" min="0" step="0.01" value="20000"
                                   class="form-control form-control-sm" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small">Fecha inicio</label>
                            <input name="FechaInicio" type="date"
                                   value="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   class="form-control form-control-sm" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm mt-3"
                            data-bs-toggle="tooltip" data-bs-placement="top"
                            title="Crea una nueva suscripción para este comercio.">
                        Crear suscripci&oacute;n
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="admin-card mt-4">
        <h2 class="h5 mb-3">Historial de suscripciones</h2>
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Plan</th>
                        <th>Estado</th>
                        <th>Pago</th>
                        <th>Monto</th>
                        <th>Inicio</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var historiales = comercio.Suscripciones
                        .Where(s => s.Estado == EstadoSuscripcion.Vencida ||
                                    s.Estado == EstadoSuscripcion.Cancelada ||
                                    (s.Estado == EstadoSuscripcion.Activa && suscripcion != null && s.Id != suscripcion.Id))
                        .ToList();
                    }
                    @if (historiales.Any())
                    {
                        foreach (var item in historiales)
                        {
                            var rowClass = (item.Estado == EstadoSuscripcion.Cancelada ||
                                           item.Estado == EstadoSuscripcion.Vencida) ? "text-muted" : "";
                            <tr class="@rowClass">
                                <td>@item.Plan</td>
                                <td>
                                    @if (item.Estado == EstadoSuscripcion.Cancelada)
                                    {
                                        <span class="status-badge status-rejected">Cancelada</span>
                                    }
                                    else if (item.Estado == EstadoSuscripcion.Vencida)
                                    {
                                        <span class="status-badge status-rejected">Vencida</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-accepted">Activa (anterior)</span>
                                    }
                                </td>
                                <td>@item.EstadoPago</td>
                                <td>@item.MontoMensual.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))</td>
                                <td>@item.FechaInicio.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                Sin historial de suscripciones vencidas o canceladas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
