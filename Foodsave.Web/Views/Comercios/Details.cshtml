@model Foodsave.Web.Models.ComercioAdministracionViewModel

@{
    ViewData["Title"] = "Detalle de comercio";
    var comercio = Model.Comercio;
    var suscripcion = Model.SuscripcionActual;
    var comercioStatusClass = comercio.EstadoAdministrativo switch
    {
        EstadoAdministrativo.Activo => "status-accepted",
        EstadoAdministrativo.Inhabilitado => "status-rejected",
        _ => "status-pending"
    };
    var pagoStatusClass = Model.EstadoPagoEfectivo switch
    {
        EstadoPagoSuscripcion.AlDia => "status-accepted",
        EstadoPagoSuscripcion.Vencido => "status-rejected",
        _ => "status-pending"
    };
}

<section class="py-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
        <div>
            <div class="d-flex align-items-center flex-wrap gap-2 mb-2">
                <h1 class="h2 mb-0">@comercio.Nombre</h1>
                <span class="status-badge @comercioStatusClass">
                    @comercio.EstadoAdministrativo
                </span>
            </div>
            <p class="lead mb-0">@comercio.Rubro</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-self-lg-start">
            @if (suscripcion is not null)
            {
                <a class="btn btn-primary"
                   asp-action="RegistrarPago"
                   asp-route-id="@comercio.Id"
                   data-bs-toggle="tooltip" data-bs-placement="top"
                   title="Registra un pago y extiende el vencimiento 30 días.">
                    Registrar pago
                </a>
            }
            <a class="btn btn-outline-secondary"
               asp-action="Editar"
               asp-route-id="@comercio.Id"
               data-bs-toggle="tooltip" data-bs-placement="top"
               title="Editar datos del comercio y su titular.">
                Editar comercio
            </a>
            <a class="btn btn-outline-primary"
               asp-action="Index">
                Volver a comercios
            </a>
        </div>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger">@error</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="info-card h-100">
                <h2 class="h5">Datos del comercio</h2>
                <p class="mb-1"><strong>Dirección:</strong> @comercio.Direccion</p>
                <p class="mb-0"><strong>Teléfono:</strong> @comercio.Telefono</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="info-card h-100">
                <h2 class="h5">Titular</h2>
                <p class="mb-1">
                    <strong>Nombre:</strong>
                    @comercio.Titular.Nombre @comercio.Titular.Apellido
                </p>
                <p class="mb-1"><strong>Email:</strong> @comercio.Titular.Email</p>
                <p class="mb-0"><strong>Teléfono:</strong> @comercio.Titular.Telefono</p>
            </div>
        </div>
    </div>

    <div class="admin-card mb-4">
        <h2 class="h5 mb-3">Estado administrativo</h2>
        <div class="d-flex flex-wrap gap-2">
            @if (comercio.EstadoAdministrativo == EstadoAdministrativo.Inhabilitado)
            {
                <form asp-action="Reactivar"
                      asp-route-id="@comercio.Id"
                      method="post">
                    <button type="submit" class="btn btn-success"
                            data-bs-toggle="tooltip" data-bs-placement="top"
                            title="Vuelve a dar de alta al comercio.">
                        Reactivar comercio
                    </button>
                </form>
            }
            else
            {
                <form asp-action="Inhabilitar"
                      asp-route-id="@comercio.Id"
                      method="post">
                    <button type="submit" class="btn btn-outline-danger"
                            data-bs-toggle="tooltip" data-bs-placement="top"
                            title="Desactiva el comercio sin borrar sus datos.">
                        Inhabilitar comercio
                    </button>
                </form>
            }

            @if (suscripcion is not null)
            {
                <form asp-action="MarcarPendientePago"
                      asp-route-id="@comercio.Id"
                      method="post">
                    <button type="submit" class="btn btn-outline-warning"
                            data-bs-toggle="tooltip" data-bs-placement="top"
                            title="Marca como pendiente sin registrar pago.">
                        Marcar pendiente de pago
                    </button>
                </form>
                <form asp-action="MarcarAlDia"
                      asp-route-id="@comercio.Id"
                      method="post">
                    <button type="submit" class="btn btn-outline-success"
                            data-bs-toggle="tooltip" data-bs-placement="top"
                            title="Extiende el vencimiento 30 días sin registrar un cobro.">
                        Marcar al día sin cobro
                    </button>
                </form>
            }
        </div>
        <p class="small text-muted mb-0 mt-3">
            Marcar al día no registra ingresos. Para contabilizar un cobro,
            usá “Registrar pago”.
        </p>
    </div>

        @if (suscripcion is not null)
        {
            <div class="admin-card mb-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                    <div>
                        <h2 class="h5 mb-1">Suscripci&oacute;n</h2>
                        <span class="status-badge @pagoStatusClass">@Model.EstadoPagoEfectivo</span>
                    </div>
                    <a class="btn btn-sm btn-outline-primary"
                       asp-action="Suscripcion" asp-route-id="@comercio.Id">
                        Gestionar suscripci&oacute;n
                    </a>
                </div>
                <div class="row g-2 small">
                    <div class="col-6 col-md-3">
                        <strong>Plan:</strong> @suscripcion.Plan
                    </div>
                    <div class="col-6 col-md-3">
                        <strong>Monto:</strong>
                        @suscripcion.MontoMensual.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("es-AR"))
                    </div>
                    <div class="col-6 col-md-3">
                        <strong>Inicio:</strong> @suscripcion.FechaInicio.ToString("dd/MM/yyyy")
                    </div>
                    <div class="col-6 col-md-3">
                        <strong>Vencimiento:</strong> @suscripcion.FechaProximoVencimiento.ToString("dd/MM/yyyy")
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="admin-card mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">Suscripci&oacute;n</h2>
                    <a class="btn btn-primary btn-sm"
                       asp-action="Suscripcion" asp-route-id="@comercio.Id">
                        Crear suscripci&oacute;n
                    </a>
                </div>
                <p class="text-muted small mb-0 mt-2">Este comercio no tiene una suscripci&oacute;n activa.</p>
            </div>
        }

        <div class="admin-card">
            <h2 class="h5 mb-3">Pagos registrados</h2>
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Plan</th>
                        <th>Monto</th>
                        <th>Observación</th>
                    </tr>
                </thead>
                <tbody>
                    @if (comercio.Pagos.Any())
                    {
                        foreach (var pago in comercio.Pagos)
                        {
                            <tr>
                                <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                                <td>@pago.Suscripcion.Plan</td>
                                <td>
                                    @pago.Monto.ToString(
                                        "C",
                                        System.Globalization.CultureInfo.GetCultureInfo("es-AR"))
                                </td>
                                <td>@(pago.Observacion ?? "Sin observación")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                Todavía no hay pagos registrados.
                                <a class="btn btn-link btn-sm p-0 ms-2 align-baseline"
                                   asp-action="RegistrarPago" asp-route-id="@comercio.Id">
                                    Registrar primer pago
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
