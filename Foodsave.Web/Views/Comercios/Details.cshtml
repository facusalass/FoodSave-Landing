@model Foodsave.Web.Models.Comercio

@{
    ViewData["Title"] = "Detalle de comercio";
}

<section class="py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h2 mb-2">@Model.Nombre</h1>
            <p class="lead mb-0">@Model.Rubro</p>
        </div>
        <a class="btn btn-primary align-self-md-start" asp-controller="Comercios" asp-action="Index">Volver a comercios</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="info-card h-100">
                <h2 class="h5">Datos del comercio</h2>
                <p class="mb-1"><strong>Direcci&oacute;n:</strong> @Model.Direccion</p>
                <p class="mb-0"><strong>Tel&eacute;fono:</strong> @Model.Telefono</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="info-card h-100">
                <h2 class="h5">Titular</h2>
                <p class="mb-1"><strong>Nombre:</strong> @Model.Titular.Nombre @Model.Titular.Apellido</p>
                <p class="mb-1"><strong>Email:</strong> @Model.Titular.Email</p>
                <p class="mb-0"><strong>Tel&eacute;fono:</strong> @Model.Titular.Telefono</p>
            </div>
        </div>
    </div>

    <div class="admin-card">
        <h2 class="h5 mb-3">Suscripciones</h2>
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Plan</th>
                        <th>Estado</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var suscripcion in Model.Suscripciones)
                    {
                        <tr>
                            <td>@suscripcion.Plan</td>
                            <td>@suscripcion.Estado</td>
                            <td>@suscripcion.FechaInicio.ToShortDateString()</td>
                            <td>@suscripcion.FechaFin.ToShortDateString()</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
