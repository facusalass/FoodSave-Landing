@model Foodsave.Web.Models.ComercioAdministracionViewModel

@{
    ViewData["Title"] = "Detalle de comercio";
    var comercio = Model.Comercio;
    var suscripcion = Model.SuscripcionActual;
    var comercioStatusClass = comercio.EstadoAdministrativo switch
    {
        EstadoAdministrativo.Activo => "status-accepted",
        EstadoAdministrativo.Inhabilitado => "status-rejected",
        _ => "status-pending"
    };
    var pagoStatusClass = Model.EstadoPagoEfectivo switch
    {
        EstadoPagoSuscripcion.AlDia => "status-accepted",
        EstadoPagoSuscripcion.Vencido => "status-rejected",
        _ => "status-pending"
    };
}

<section class="py-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
        <div>
            <div class="d-flex align-items-center flex-wrap gap-2 mb-2">
                <h1 class="h2 mb-0">@comercio.Nombre</h1>
                <span class="status-badge @comercioStatusClass">
                    @comercio.EstadoAdministrativo
                </span>
            </div>
            <p class="lead mb-0">@comercio.Rubro</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-self-lg-start">
            @if (suscripcion is not null)
            {
                <a class="btn btn-primary"
                   asp-action="RegistrarPago"
                   asp-route-id="@comercio.Id">
                    Registrar pago
                </a>
            }
            <a class="btn btn-outline-primary"
               asp-action="Index">
                Volver a comercios
            </a>
        </div>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger">@error</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="info-card h-100">
                <h2 class="h5">Datos del comercio</h2>
                <p class="mb-1"><strong>Dirección:</strong> @comercio.Direccion</p>
                <p class="mb-0"><strong>Teléfono:</strong> @comercio.Telefono</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="info-card h-100">
                <h2 class="h5">Titular</h2>
                <p class="mb-1">
                    <strong>Nombre:</strong>
                    @comercio.Titular.Nombre @comercio.Titular.Apellido
                </p>
                <p class="mb-1"><strong>Email:</strong> @comercio.Titular.Email</p>
                <p class="mb-0"><strong>Teléfono:</strong> @comercio.Titular.Telefono</p>
            </div>
        </div>
    </div>

    <div class="admin-card mb-4">
        <h2 class="h5 mb-3">Estado administrativo</h2>
        <div class="d-flex flex-wrap gap-2">
            @if (comercio.EstadoAdministrativo == EstadoAdministrativo.Inhabilitado)
            {
                <form asp-action="Reactivar"
                      asp-route-id="@comercio.Id"
                      method="post">
                    <button type="submit" class="btn btn-success">
                        Reactivar comercio
                    </button>
                </form>
            }
            else
            {
                <form asp-action="Inhabilitar"
                      asp-route-id="@comercio.Id"
                      method="post">
                    <button type="submit" class="btn btn-outline-danger">
                        Inhabilitar comercio
                    </button>
                </form>
            }

            @if (suscripcion is not null)
            {
                <form asp-action="MarcarPendientePago"
                      asp-route-id="@comercio.Id"
                      method="post">
                    <button type="submit" class="btn btn-outline-warning">
                        Marcar pendiente de pago
                    </button>
                </form>
                <form asp-action="MarcarAlDia"
                      asp-route-id="@comercio.Id"
                      method="post">
                    <button type="submit" class="btn btn-outline-success">
                        Marcar al día sin cobro
                    </button>
                </form>
            }
        </div>
        <p class="small text-muted mb-0 mt-3">
            Marcar al día no registra ingresos. Para contabilizar un cobro,
            usá “Registrar pago”.
        </p>
    </div>

    @if (suscripcion is not null)
    {
        <div class="admin-card mb-4">
            <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
                <h2 class="h5 mb-0">Suscripción actual</h2>
                <span class="status-badge @pagoStatusClass">
                    @Model.EstadoPagoEfectivo
                </span>
            </div>

            <form asp-action="ActualizarSuscripcion"
                  asp-route-id="@comercio.Id"
                  method="post">
                <input type="hidden" name="ComercioId" value="@comercio.Id" />
                <input type="hidden" name="SuscripcionId" value="@suscripcion.Id" />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label for="plan" class="form-label">Plan</label>
                        <select id="plan" name="Plan" class="form-select">
                            <option value="Estandar"
                                    selected="@(suscripcion.Plan == PlanSuscripcion.Estandar)">
                                Estándar
                            </option>
                            <option value="Pro"
                                    selected="@(suscripcion.Plan == PlanSuscripcion.Pro)">
                                Pro
                            </option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label for="montoMensual" class="form-label">
                            Monto mensual (ARS)
                        </label>
                        <input id="montoMensual"
                               name="MontoMensual"
                               type="number"
                               min="0"
                               step="0.01"
                               value="@suscripcion.MontoMensual.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                               class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="fechaProximoVencimiento" class="form-label">
                            Próximo vencimiento
                        </label>
                        <input id="fechaProximoVencimiento"
                               name="FechaProximoVencimiento"
                               type="date"
                               value="@suscripcion.FechaProximoVencimiento.ToString("yyyy-MM-dd")"
                               class="form-control" />
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-outline-primary">
                        Guardar suscripción
                    </button>
                </div>
            </form>

            <hr />
            <div class="row g-2 small">
                <div class="col-md-4">
                    <strong>Último pago:</strong>
                    @(suscripcion.FechaUltimoPago?.ToString("dd/MM/yyyy") ?? "Sin pagos")
                </div>
                <div class="col-md-4">
                    <strong>Inicio:</strong>
                    @suscripcion.FechaInicio.ToString("dd/MM/yyyy")
                </div>
                <div class="col-md-4">
                    <strong>Fin contractual:</strong>
                    @suscripcion.FechaFin.ToString("dd/MM/yyyy")
                </div>
            </div>
        </div>
    }

    <div class="admin-card mb-4">
        <h2 class="h5 mb-3">Historial de suscripciones</h2>
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Plan</th>
                        <th>Estado contractual</th>
                        <th>Estado de pago guardado</th>
                        <th>Monto mensual</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                    </tr>
                </thead>
                <tbody>
                    @if (comercio.Suscripciones.Any())
                    {
                        foreach (var item in comercio.Suscripciones)
                        {
                            <tr>
                                <td>@item.Plan</td>
                                <td>@item.Estado</td>
                                <td>@item.EstadoPago</td>
                                <td>
                                    @item.MontoMensual.ToString(
                                        "C",
                                        System.Globalization.CultureInfo.GetCultureInfo("es-AR"))
                                </td>
                                <td>@item.FechaInicio.ToString("dd/MM/yyyy")</td>
                                <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                El comercio no tiene suscripciones.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="admin-card">
        <h2 class="h5 mb-3">Pagos registrados</h2>
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Plan</th>
                        <th>Monto</th>
                        <th>Observación</th>
                    </tr>
                </thead>
                <tbody>
                    @if (comercio.Pagos.Any())
                    {
                        foreach (var pago in comercio.Pagos)
                        {
                            <tr>
                                <td>@pago.FechaPago.ToString("dd/MM/yyyy")</td>
                                <td>@pago.Suscripcion.Plan</td>
                                <td>
                                    @pago.Monto.ToString(
                                        "C",
                                        System.Globalization.CultureInfo.GetCultureInfo("es-AR"))
                                </td>
                                <td>@(pago.Observacion ?? "Sin observación")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                Todavía no hay pagos registrados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
