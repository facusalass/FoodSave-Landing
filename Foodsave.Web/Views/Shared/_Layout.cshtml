<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FoodSave — Conectamos comercios con usuarios para reducir el desperdicio de comida. Reservá ofertas del día y Mystery Boxes." />
    <title>@ViewData["Title"] - FoodSave</title>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dcasnymut/image/upload/v1782842106/food_pgn_j6iu1q.png" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Foodsave.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm foodsave-navbar">
            <div class="container">
                <a class="navbar-brand fw-bold text-decoration-none"
                   asp-controller="Home" asp-action="Index">
                    <img src="https://res.cloudinary.com/dcasnymut/image/upload/v1782842106/food_pgn_j6iu1q.png"
                         alt="FoodSave" class="brand-logo" />
                    FoodSave
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarContent" aria-controls="navbarContent"
                        aria-expanded="false" aria-label="Menú">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto align-items-sm-center gap-sm-1">
                        @{
                            var active = ViewData["ActivePage"] as string;
                        }
                        <li class="nav-item">
                            <a class="nav-link @(active == "Home" ? "active" : "")"
                               asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(active == "Solicitudes" ? "active" : "")"
                                   asp-controller="SolicitudesComercio"
                                   asp-action="Index">Solicitudes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(active == "Comercios" ? "active" : "")"
                                   asp-controller="Comercios"
                                   asp-action="Index">Comercios</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(active == "Estadisticas" ? "active" : "")"
                                   asp-controller="Estadisticas"
                                   asp-action="Index">Estadísticas</a>
                            </li>
                            <li class="nav-item d-none d-sm-block">
                                <span class="navbar-text navbar-user px-2">
                                    @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post">
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger ms-sm-1">
                                        Salir
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="SolicitudesComercio"
                                   asp-action="Create">Sumar mi comercio</a>
                            </li>
                            <li class="nav-item ms-sm-1">
                                <a class="btn btn-sm btn-primary px-3"
                                   asp-controller="Auth" asp-action="Login">
                                    Ingresar
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @{
        var breadcrumb = ViewData["Breadcrumb"] as (string Label, string? Action, string? Controller)[];
    }
    @if (breadcrumb is { Length: > 0 })
    {
        <div class="container">
            <nav class="foodsave-breadcrumb" aria-label="breadcrumb">
                @for (int i = 0; i < breadcrumb.Length; i++)
                {
                    var item = breadcrumb[i];
                    if (i < breadcrumb.Length - 1)
                    {
                        <a asp-controller="@item.Controller" asp-action="@item.Action">@item.Label</a>
                        <span class="breadcrumb-sep">›</span>
                    }
                    else
                    {
                        <span>@item.Label</span>
                    }
                }
            </nav>
        </div>
    }

    <div class="page-content">
        <div class="container">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="foodsave-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-5">
                    <p class="footer-brand mb-2">
                        <img src="https://res.cloudinary.com/dcasnymut/image/upload/v1782842106/food_pgn_j6iu1q.png"
                             alt="FoodSave" class="footer-logo" />
                        FoodSave
                    </p>
                    <p class="mb-3" style="max-width:300px;">
                        Reducimos el desperdicio de comida conectando comercios
                        locales con usuarios que buscan buenos precios.
                    </p>
                </div>
                <div class="col-md-3">
                    <h5>Plataforma</h5>
                    <a asp-controller="Home" asp-action="Index">Inicio</a><br />
                    <a asp-controller="SolicitudesComercio" asp-action="Create">
                        Sumar mi comercio
                    </a><br />
                    <a asp-controller="Auth" asp-action="Login">Ingresar</a><br />
                    <a asp-controller="Home" asp-action="Privacy">
                        Política de privacidad
                    </a>
                </div>
                <div class="col-md-4">
                    <h5>Contacto</h5>
                    <p class="mb-2" style="font-size:0.85rem;">
                        Escribinos por WhatsApp o completá el formulario y te
                        contactamos.
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="https://wa.me/543624250501"
                           target="_blank" rel="noopener noreferrer"
                           class="btn-social btn-whatsapp">
                            <svg class="social-svg" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                            </svg>
                            WhatsApp
                        </a>
                        <a href="https://instagram.com/foodsave.ok"
                           target="_blank" rel="noopener noreferrer"
                           class="btn-social btn-instagram">
                            <svg class="social-svg" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                                <circle cx="12" cy="12" r="5"/>
                                <circle cx="17.5" cy="6.5" r="1.5"/>
                            </svg>
                            Instagram
                        </a>
                        <a asp-controller="SolicitudesComercio"
                           asp-action="Create"
                           class="btn-social btn-form">
                            <svg class="social-svg" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                            Formulario
                        </a>
                    </div>
                </div>
            </div>
            <hr />
            <p class="footer-bottom text-center mb-0">
                &copy; @DateTime.Now.Year FoodSave. Todos los derechos reservados.
            </p>
        </div>
    </footer>

    <a href="https://wa.me/543624250501"
       target="_blank" rel="noopener noreferrer"
       class="whatsapp-float"
       aria-label="Contactar por WhatsApp"
       title="Contactar por WhatsApp">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="26" height="26"
             fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
        </svg>
    </a>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (el) {
                return new bootstrap.Tooltip(el);
            });
        });

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('form').forEach(function (form) {
                form.addEventListener('submit', function () {
                    var btn = this.querySelector('button[type="submit"]');
                    if (!btn || btn.disabled) return;

                    var $form = typeof $ !== 'undefined' ? $(this) : null;
                    if ($form && $form.data('validator') && !$form.valid()) return;
                    if (!this.checkValidity()) return;

                    var orig = btn.textContent.trim();
                    btn.disabled = true;
                    btn.setAttribute('data-orig-text', orig);
                    btn.innerHTML = '<span class="spinner-dot"></span> ' + (orig.length < 12 ? 'Guardando…' : 'Enviando…');

                    setTimeout(function () {
                        if (btn.disabled) {
                            btn.disabled = false;
                            btn.innerHTML = btn.getAttribute('data-orig-text') || orig;
                        }
                    }, 8000);
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
