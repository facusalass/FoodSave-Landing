@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="py-5">
    <div class="text-center">
        <h1 class="display-4 fw-bold" style="color: var(--foodsave-orange);">
            Error
        </h1>
        <p class="lead mt-3">
            Ocurri&oacute; un error al procesar tu solicitud.
        </p>
        @if (Model.ShowRequestId)
        {
            <p class="small text-muted">
                <strong>ID de solicitud:</strong>
                <code>@Model.RequestId</code>
            </p>
        }
        <a class="btn btn-outline-primary mt-3"
           asp-controller="Home" asp-action="Index">
            Volver al inicio
        </a>
    </div>
</section>
