@{
    ViewData["Title"] = "Solicitud enviada";
}

<section class="login-section py-5">
    <div class="login-card text-center">
        <p class="section-label mb-2">Solicitud recibida</p>
        <h1 class="h3 mb-3">¡Gracias por querer sumarte!</h1>
        <p class="mb-4">
            Tu solicitud fue enviada correctamente. Nos vamos a comunicar con
            vos para continuar el alta en FoodSave.
        </p>
        <a class="btn btn-primary"
           asp-controller="Home"
           asp-action="Index">
            Volver al inicio
        </a>
    </div>
</section>
